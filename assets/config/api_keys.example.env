# Copy needed values into the MCP server environment.
# Leave unused providers unset; the MCP will return manual/provider tasks where possible.

OSINT_INVESTIGATOR_HOME=${HOME}/.osint-investigator

# Optional public OSINT toolkit index.
# Expected format: a Markdown SUMMARY.md-like index with tool links under tools/<slug>/README.md.
OSINT_TOOLKIT_SUMMARY_URL=
OSINT_TOOLKIT_RAW_BASE=
OSINT_TOOLKIT_REPO_BASE=
OSINT_TOOLKIT_PAGE_BASE=

# Social and messaging
TGSTAT_TOKEN=
OPENMEASURES_API_KEY=
YOUTUBE_API_KEY=
TIKTOK_API_KEY=

# Maps, satellite, and street-level imagery
MAPILLARY_ACCESS_TOKEN=
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=
PLANET_API_KEY=
SKYFI_API_KEY=
NASA_FIRMS_MAP_KEY=
GFW_API_KEY=

# Websites, infrastructure, and breach/intelligence indexes
URLSCAN_API_KEY=
PUBLICWWW_API_KEY=
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=
INTELX_API_KEY=
