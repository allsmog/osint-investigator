    {
      "id": "archiving",
      "name": "Archiving",
      "providers": [
        {
          "id": "wayback_cdx",
          "name": "Wayback CDX",
          "mode": "direct",
          "tools": ["osint_wayback_lookup"],
          "auth": "none",
          "url": "https://web.archive.org/cdx"
        },
        {
          "id": "wayback_save",
          "name": "Wayback Save Page Now",
          "mode": "direct",
          "tools": ["osint_archive_url"],
          "auth": "none",
          "url": "https://web.archive.org/save/"
        },
        {
          "id": "archive_today",
